<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="ru.rerumu.lists.dao.tag.TagsMapper">

    <resultMap id="TagResultMap" type="ru.rerumu.lists.model.tag.TagDTO">
        <constructor>
            <idArg name="tagId" column="tag_id" javaType="Long"/>
            <arg name="name" column="name" javaType="String"/>
            <arg name="userId" column="user_user_id" javaType="Long"/>
        </constructor>
    </resultMap>

    <select id="findByBookIds">
<!--        <![CDATA[-->
            select
                t.tag_id,
                t.name,
                t.user_user_id
            from
                lists.tags t
                    inner join lists.books_tags bt
                        on bt.tag_tag_id = t.tag_id
            <where>
                <foreach collection="bookIds" index="index" item="item" open="bt.book_book_id in (" separator="," close=")" >
                    #{item}
                </foreach>
            </where>
<!--        ]]>-->
    </select>

    <insert id="create" parameterType="ru.rerumu.lists.model.Game">
        insert into games(game_id, user_user_id, title, insert_date, note)
        values(#{gameId},#{user.userId},#{title},#{createDateUTC}, #{note})
    </insert>

    <select id="nextval" resultType="Integer">
        SELECT nextval('game_id_seq');
    </select>

    <select id="findById" parameterType="Integer" resultMap="GameResultMap">
        select  g.game_id as gameId,
                g.title,
                u.USER_ID as userId,
                u.name,
                u.password,
                g.insert_date as createDateUTC,
                g.note
        from    games g
                inner join users u
                on u.USER_ID = g.user_user_id
        where g.game_id=#{gameId}
    </select>

    <delete id="delete">
        delete from games
        where game_id=#{id}
    </delete>



</mapper>